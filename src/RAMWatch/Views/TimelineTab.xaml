<UserControl x:Class="RAMWatch.Views.TimelineTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RAMWatch.ViewModels"
             xmlns:controls="clr-namespace:RAMWatch.Controls">

    <Grid Margin="8,8,8,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Era banner -->
            <RowDefinition Height="Auto" />   <!-- Section header + filters -->
            <RowDefinition Height="*" />      <!-- Timeline entries -->
        </Grid.RowDefinitions>

        <!-- ═══ Era banner ═══════════════════════════════════════════════
             Three mutually-exclusive states:
               1. ACTIVE ERA — green strip, shows name + start date + End btn
               2. UNNAMED CONFIG — amber nudge: "you just changed BIOS, name it?"
               3. NO ERA — dim strip with "Start new config" button
             The "Start new config" flow inline-expands to a TextBox + Start/Cancel
             (IsNamingEra) so we don't need a modal dialog for a one-field input.
          ═════════════════════════════════════════════════════════════════ -->
        <!-- Hero element — a returning user's eye lands here first to see
             "what am I testing right now?" Padding and type scale bumped up
             from the surrounding 12pt/6px baseline. -->
        <Border Grid.Row="0"
                Margin="0,0,0,8"
                CornerRadius="3"
                Padding="12,9">
            <Border.Style>
                <Style TargetType="Border">
                    <!-- Default: neutral (no-era state). -->
                    <Setter Property="Background" Value="{StaticResource BgPanel}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasActiveEra}" Value="True">
                            <Setter Property="Background" Value="#1A1F3B4D" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasUnnamedConfig}" Value="True">
                            <Setter Property="Background" Value="#33FFB300" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <!-- (1) Active-era state -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasActiveEra}" Value="True" />
                                        <Condition Binding="{Binding IsNamingEra}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Ellipse Width="10" Height="10"
                             Fill="{StaticResource StatusGreen}"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0" />
                    <TextBlock Text="Testing: "
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="{StaticResource UIFont}"
                               FontSize="14"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ActiveEraName}"
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="{StaticResource UIFont}"
                               FontWeight="Bold"
                               FontSize="14"
                               VerticalAlignment="Center" />
                    <TextBlock Text=" — "
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="{StaticResource UIFont}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding ActiveEraStartText}"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="{StaticResource UIFont}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,2,0,0" />
                    <Button Content="Start new"
                            Command="{Binding StartNextEraCommand}"
                            Style="{StaticResource DarkButton}"
                            Margin="12,0,0,0"
                            Padding="10,2"
                            FontSize="11"
                            ToolTip="End this campaign and immediately name the next one."
                            AutomationProperties.Name="End this era and start a new one" />
                    <Button Content="End"
                            Command="{Binding EndActiveEraCommand}"
                            Style="{StaticResource DarkButton}"
                            Margin="6,0,0,0"
                            Padding="10,2"
                            FontSize="11"
                            AutomationProperties.Name="End active tuning era" />
                </StackPanel>

                <!-- (2 + 3) No active era — nudge if unnamed, neutral otherwise.
                     IsNamingEra=False: button row.
                     IsNamingEra=True:  TextBox + Start + Cancel. -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasActiveEra}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <!-- Button row -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNamingEra}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Amber dot when a recent unnamed config change is detected;
                             grey dot otherwise. -->
                        <Ellipse Width="8" Height="8"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource TextDisabled}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUnnamedConfig}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource StatusAmber}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="{StaticResource UIFont}"
                                   FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                    <Setter Property="Text" Value="No active tuning config. Name this boot to start a campaign." />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUnnamedConfig}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                            <Setter Property="Text" Value="New BIOS config detected — name it to trace tests and errors back to this boot." />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Content="Start new config"
                                Command="{Binding StartNamingCommand}"
                                Style="{StaticResource DarkButton}"
                                Margin="12,0,0,0"
                                Padding="10,2"
                                FontSize="11"
                                AutomationProperties.Name="Start new tuning era" />
                    </StackPanel>

                    <!-- Inline name entry -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNamingEra}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="Config name"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontFamily="{StaticResource UIFont}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Text="{Binding NewEraName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="220"
                                 Background="{StaticResource BgAccent}"
                                 Foreground="{StaticResource TextPrimary}"
                                 BorderThickness="0"
                                 Padding="6,3"
                                 FontFamily="{StaticResource UIFont}"
                                 FontSize="12"
                                 VerticalAlignment="Center"
                                 AutomationProperties.Name="Tuning config name">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"  Command="{Binding ConfirmNewEraCommand}" />
                                <KeyBinding Key="Escape" Command="{Binding CancelNamingCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Content="Start"
                                Command="{Binding ConfirmNewEraCommand}"
                                Style="{StaticResource DarkButton}"
                                Margin="8,0,0,0"
                                Padding="10,2"
                                FontSize="11"
                                IsDefault="True"
                                AutomationProperties.Name="Confirm new tuning era" />
                        <Button Content="Cancel"
                                Command="{Binding CancelNamingCommand}"
                                Style="{StaticResource DarkButton}"
                                Margin="6,0,0,0"
                                Padding="10,2"
                                FontSize="11"
                                IsCancel="True"
                                AutomationProperties.Name="Cancel naming" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Section header + log-test button + type filters.
             Log Test Result lives here (not on the global action bar) because
             tests file under the active era — the button wants to sit near
             the banner that shows what era they'll attach to. -->
        <DockPanel Grid.Row="1">
            <TextBlock Text="TIMELINE"
                       Style="{StaticResource SectionHeader}"
                       DockPanel.Dock="Left" />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,0,2">
                <CheckBox Content="Snap" IsChecked="{Binding ShowSnapshot}"
                          Foreground="{StaticResource StatusGreen}" FontSize="10" Margin="0,0,6,0" />
                <CheckBox Content="Pass" IsChecked="{Binding ShowPass}"
                          Foreground="{StaticResource StatusGreen}" FontSize="10" Margin="0,0,6,0" />
                <CheckBox Content="Fail" IsChecked="{Binding ShowFail}"
                          Foreground="{StaticResource StatusRed}" FontSize="10" Margin="0,0,6,0" />
                <CheckBox Content="Change" IsChecked="{Binding ShowMajorChange}"
                          Foreground="{StaticResource InteractiveBlue}" FontSize="10" Margin="0,0,6,0"
                          ToolTip="Deliberate tuning changes — primary timings, voltages, clocks, controller mode." />
                <CheckBox Content="Retrain" IsChecked="{Binding ShowChange}"
                          Foreground="{StaticResource StatusAmber}" FontSize="10" Margin="0,0,6,0"
                          ToolTip="Auto memory retraining of secondary timings. Coalesced per boot. Noisy — off by default." />
                <CheckBox Content="Drift" IsChecked="{Binding ShowDrift}"
                          Foreground="{StaticResource StatusRed}" FontSize="10" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,2">
                <Button Content="Log test result"
                        Style="{StaticResource DarkButton}"
                        Command="{Binding DataContext.LogValidationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Padding="10,2"
                        FontSize="11"
                        AutomationProperties.Name="Log test result"
                        ToolTip="Log a stress-test pass or fail under the current tuning config." />
                <TextBlock Text="{Binding DataContext.ValidationConfirmation, RelativeSource={RelativeSource AncestorType=Window}}"
                           Foreground="{StaticResource StatusGreen}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </StackPanel>
        </DockPanel>

        <!-- Empty state -->
        <TextBlock Grid.Row="2"
                   Text="No timeline entries yet. Snapshots, tests, changes, and drift events will appear here."
                   Foreground="{StaticResource TextSecondary}"
                   FontStyle="Italic"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="0,32,0,0"
                   Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                   AutomationProperties.Name="Timeline empty" />

        <!-- Timeline list -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,4,0,0"
                      Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibility}}">
            <ItemsControl ItemsSource="{Binding Entries}"
                          AutomationProperties.Name="Timeline entries">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TimelineEntry}">
                        <Border Margin="0,0,0,4"
                                Background="{StaticResource BgPanel}"
                                CornerRadius="2"
                                Padding="0">
                            <DockPanel>
                                <!-- Colored left border strip indicating entry type -->
                                <Border DockPanel.Dock="Left" Width="4" CornerRadius="2,0,0,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource InteractiveBlue}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.ConfigChange}">
                                                    <Setter Property="Background" Value="{StaticResource StatusAmber}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.Drift}">
                                                    <Setter Property="Background" Value="{StaticResource StatusRed}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.ValidationPass}">
                                                    <Setter Property="Background" Value="{StaticResource StatusGreen}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.ValidationFail}">
                                                    <Setter Property="Background" Value="{StaticResource StatusRed}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.Snapshot}">
                                                    <Setter Property="Background" Value="{StaticResource StatusGreen}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Delete button — docked right so it doesn't compress the content area -->
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding RequestDeleteCommand}"
                                        Width="60"
                                        Height="24"
                                        Margin="4,8,8,8"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource UIFont}"
                                        FontSize="11"
                                        Padding="0"
                                        Cursor="Hand"
                                        AutomationProperties.Name="Delete timeline entry"
                                        FocusVisualStyle="{StaticResource FocusVisual}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                            <!-- Normal state: muted "×" -->
                                            <Setter Property="Content" Value="×" />
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <!-- Confirmation pending: red background + "Confirm?" label -->
                                                <DataTrigger Binding="{Binding DeleteConfirmPending}" Value="True">
                                                    <Setter Property="Content" Value="Confirm?" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                                    <Setter Property="Background" Value="{StaticResource StatusRed}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Content area -->
                                <StackPanel Margin="10,8,10,8">
                                    <!-- Top row: type label + timestamp. Glyph shape
                                         tells derived (diamond) vs. primary-observation
                                         (circle); the colored left strip already conveys
                                         severity, so these two channels are independent. -->
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding TimestampDisplay}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                        <controls:ProvenanceGlyph SensorKey="{Binding ProvenanceKey}"
                                                                  DisplayName="{Binding TypeLabel}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,6,0" />
                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Typography.Capitals="AllSmallCaps">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource InteractiveBlue}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.ConfigChange}">
                                                            <Setter Property="Foreground" Value="{StaticResource StatusAmber}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.Drift}">
                                                            <Setter Property="Foreground" Value="{StaticResource StatusRed}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.ValidationPass}">
                                                            <Setter Property="Foreground" Value="{StaticResource StatusGreen}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.ValidationFail}">
                                                            <Setter Property="Foreground" Value="{StaticResource StatusRed}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding EntryType}" Value="{x:Static vm:TimelineEntryType.Snapshot}">
                                                            <Setter Property="Foreground" Value="{StaticResource StatusGreen}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding TypeLabel, Mode=OneWay}" />
                                        </TextBlock>
                                    </DockPanel>

                                    <!-- Summary text -->
                                    <TextBlock Text="{Binding Summary}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />

                                    <!-- Timing context line — hidden when no snapshot data available -->
                                    <TextBlock Text="{Binding TimingSummary}"
                                               Foreground="{StaticResource TextDisabled}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="10"
                                               Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TimingSummary}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Era footer — "under <era name>" — gives every
                                         row a trace back to the campaign it was filed
                                         under, so "FAIL y-cruncher" isn't homeless. -->
                                    <TextBlock Foreground="{StaticResource TextDisabled}"
                                               FontFamily="{StaticResource UIFont}"
                                               FontSize="10"
                                               FontStyle="Italic"
                                               Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EraName}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="under " />
                                        <Run Text="{Binding EraName, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
