<Window x:Class="RAMWatch.Views.EventDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event Detail"
        Width="780" Height="640"
        MinWidth="600" MinHeight="480"
        Style="{StaticResource DarkWindow}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        AutomationProperties.Name="Event Detail">

    <Grid Margin="16,12,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header -->
            <RowDefinition Height="160" />    <!-- Event list -->
            <RowDefinition Height="*" />      <!-- Decoded detail -->
            <RowDefinition Height="Auto" />   <!-- Close button -->
        </Grid.RowDefinitions>

        <!-- Header — source name and event count -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="SourceHeader"
                       Style="{StaticResource SectionHeader}"
                       FontSize="14"
                       Text="EVENT DETAIL" />
            <TextBlock x:Name="EventCountLabel"
                       DockPanel.Dock="Right"
                       Foreground="{StaticResource TextSecondary}"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
        </DockPanel>

        <!-- Event list — newest first. Selection drives the decoded panel below. -->
        <Border Grid.Row="1"
                Background="{StaticResource BgPanel}"
                CornerRadius="2"
                Margin="0,0,0,8">
            <ListBox x:Name="EventList"
                     Background="Transparent"
                     Foreground="{StaticResource TextPrimary}"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionMode="Single"
                     AutomationProperties.Name="Event list">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BgHover}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BgAccent}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TimestampDisplay}"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ListSummary}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Decoded detail — populated by code-behind from the selected event. -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPanel}"
                CornerRadius="2"
                Padding="14,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="DetailStack" />
            </ScrollViewer>
        </Border>

        <!-- Close button -->
        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock x:Name="CopyConfirm"
                       DockPanel.Dock="Left"
                       Foreground="{StaticResource StatusGreen}"
                       FontSize="11"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <Button Content="Copy"
                        Style="{StaticResource DarkButton}"
                        Width="80"
                        Click="OnCopy"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Copy decoded event to clipboard" />
                <Button Content="Close"
                        Style="{StaticResource DarkButton}"
                        Width="80"
                        Click="OnClose"
                        IsCancel="True"
                        IsDefault="True"
                        AutomationProperties.Name="Close" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
