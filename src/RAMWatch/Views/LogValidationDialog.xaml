<Window x:Class="RAMWatch.Views.LogValidationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Test Result"
        Width="420" Height="440"
        MinWidth="360" MinHeight="380"
        Style="{StaticResource DarkWindow}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        AutomationProperties.Name="Log Test Result">

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header -->
            <RowDefinition Height="Auto" />   <!-- Tool + Duration -->
            <RowDefinition Height="Auto" />   <!-- Coverage / Cycles -->
            <RowDefinition Height="Auto" />   <!-- Pass / Fail + Error Count -->
            <RowDefinition Height="*" />      <!-- Notes -->
            <RowDefinition Height="Auto" />   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="LOG TEST RESULT"
                   Style="{StaticResource SectionHeader}"
                   Margin="0,0,0,12" />

        <!-- Row: Test Tool + Duration -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Test tool"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,3" />
                <ComboBox x:Name="TestToolCombo"
                          Style="{StaticResource DarkComboBox}"
                          ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                          AutomationProperties.Name="Test tool" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Duration"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,3" />
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="DurationBox"
                             Width="60"
                             Text="1"
                             Background="{StaticResource BgAccent}"
                             Foreground="{StaticResource TextPrimary}"
                             BorderThickness="0"
                             Padding="6,4"
                             FontFamily="{StaticResource MonoFont}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name="Duration in hours" />
                    <TextBlock Text="h"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Row: Coverage / Cycles -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock x:Name="CoverageLabel"
                       Text="Coverage / cycles"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="11"
                       Margin="0,0,0,3" />
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="CoverageBox"
                         Width="120"
                         Text=""
                         Background="{StaticResource BgAccent}"
                         Foreground="{StaticResource TextPrimary}"
                         BorderThickness="0"
                         Padding="6,4"
                         FontFamily="{StaticResource MonoFont}"
                         VerticalAlignment="Center"
                         AutomationProperties.Name="Coverage or cycles" />
                <TextBlock x:Name="CoverageUnitLabel"
                           Text="(e.g. 12400% for Karhu, cycles for TM5)"
                           Foreground="{StaticResource TextDisabled}"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Row: Pass / Fail + Error Count -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="70" />
            </Grid.ColumnDefinitions>

            <RadioButton x:Name="PassRadio"
                         Grid.Column="0"
                         Content="Pass"
                         IsChecked="True"
                         Foreground="{StaticResource StatusGreen}"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         AutomationProperties.Name="Pass" />

            <RadioButton x:Name="FailRadio"
                         Grid.Column="2"
                         Content="Fail"
                         Foreground="{StaticResource StatusRed}"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         AutomationProperties.Name="Fail" />

            <TextBlock Grid.Column="4"
                       Text="Errors"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="16,0,8,0" />
            <TextBox Grid.Column="5"
                     x:Name="ErrorCountBox"
                     Text="0"
                     Background="{StaticResource BgAccent}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderThickness="0"
                     Padding="6,4"
                     FontFamily="{StaticResource MonoFont}"
                     VerticalAlignment="Center"
                     AutomationProperties.Name="Error count" />
        </Grid>

        <!-- Notes -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Notes"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="11"
                       Margin="0,0,0,3" />
            <TextBox x:Name="NotesBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="80"
                     Background="{StaticResource BgAccent}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderThickness="0"
                     Padding="6,6"
                     FontFamily="{StaticResource UIFont}"
                     VerticalAlignment="Stretch"
                     VerticalScrollBarVisibility="Auto"
                     AutomationProperties.Name="Notes" />
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Name="ValidationErrorText"
                       Foreground="{StaticResource StatusAmber}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />

            <Button Grid.Column="1"
                    Content="Log Result"
                    Style="{StaticResource DarkButton}"
                    Width="90"
                    Click="OnLogResult"
                    IsDefault="True"
                    AutomationProperties.Name="Log Result" />

            <Button Grid.Column="3"
                    Content="Cancel"
                    Style="{StaticResource DarkButton}"
                    Width="70"
                    Click="OnCancel"
                    IsCancel="True"
                    AutomationProperties.Name="Cancel" />
        </Grid>
    </Grid>
</Window>
