<UserControl x:Class="RAMWatch.Views.TimingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is TimingsViewModel, set by MainWindow via x:Name binding -->

    <Grid Margin="16">

        <!-- No-driver overlay — visible when HasTimings is false -->
        <TextBlock Text="Timing display requires PawnIO driver"
                   Foreground="{StaticResource TextDisabled}"
                   FontFamily="{StaticResource UIFont}"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTimings}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Timing grid — visible only when HasTimings is true -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTimings}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>

                <!-- ── CLOCKS ──────────────────────────────────────────── -->
                <TextBlock Text="CLOCKS" Style="{StaticResource SectionHeader}" />
                <Border Background="{StaticResource BgPanel}"
                        CornerRadius="2"
                        Padding="12,8"
                        Margin="0,4,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="MCLK"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="48" />
                            <TextBlock Text="{Binding MclkDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="FCLK"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="48" />
                            <TextBlock Text="{Binding FclkDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="UCLK"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="48" />
                            <TextBlock Text="{Binding UclkDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── PRIMARIES ───────────────────────────────────────── -->
                <TextBlock Text="PRIMARIES" Style="{StaticResource SectionHeader}" />
                <Border Background="{StaticResource BgPanel}"
                        CornerRadius="2"
                        Padding="12,8"
                        Margin="0,4,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                        </Grid.RowDefinitions>

                        <!-- Row 0 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="CL"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding ClDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tRCDRD"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RcdrdDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tRCDWR"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RcdwrDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <!-- Row 1 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tRP"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RpDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tRAS"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RasDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tRC"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RcDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <!-- Row 2 -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="CWL"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding CwlDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="GDM"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding GdmDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Cmd"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding CommandRateDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── tRFC ────────────────────────────────────────────── -->
                <TextBlock Text="tRFC" Style="{StaticResource SectionHeader}" />
                <Border Background="{StaticResource BgPanel}"
                        CornerRadius="2"
                        Padding="12,8"
                        Margin="0,4,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="tRFC1"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RfcDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="tRFC2"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding Rfc2Display}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="tRFC4"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding Rfc4Display}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── SECONDARIES ────────────────────────────────────── -->
                <TextBlock Text="SECONDARIES" Style="{StaticResource SectionHeader}" />
                <Border Background="{StaticResource BgPanel}"
                        CornerRadius="2"
                        Padding="12,8"
                        Margin="0,4,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                        </Grid.RowDefinitions>

                        <!-- Row 0 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tRRDS"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RrdsDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tRRDL"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RrdlDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tFAW"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding FawDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <!-- Row 1 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tWTRS"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding WtrsDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tWTRL"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding WtrlDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tWR"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding WrDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <!-- Row 2 -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="tRTP"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RtpDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="RDRDSCL"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding RdrdSclDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="WRWRSCL"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding WrwrSclDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── VOLTAGES ────────────────────────────────────────── -->
                <TextBlock Text="VOLTAGES" Style="{StaticResource SectionHeader}" />
                <Border Background="{StaticResource BgPanel}"
                        CornerRadius="2"
                        Padding="12,8"
                        Margin="0,4,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="VSoC"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding VsocDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="VDIMM"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding VdimmDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
