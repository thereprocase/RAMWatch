<UserControl x:Class="RAMWatch.Views.TimingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is TimingsViewModel, set by MainWindow via x:Name binding -->

    <Grid Margin="16">

        <!-- No-driver overlay — visible when HasTimings is false -->
        <TextBlock Text="Timing display requires PawnIO driver"
                   Foreground="{StaticResource TextDisabled}"
                   FontFamily="{StaticResource UIFont}"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTimings}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Timing grid — visible only when HasTimings is true -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTimings}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>

                <!-- ── CLOCKS ──────────────────────────────────────────── -->
                <TextBlock Text="CLOCKS" Style="{StaticResource SectionHeader}" />
                <Border Background="{StaticResource BgPanel}"
                        CornerRadius="2"
                        Padding="12,8"
                        Margin="0,4,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="MCLK"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="48" />
                            <TextBlock Text="{Binding MclkDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="FCLK"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="48" />
                            <TextBlock Text="{Binding FclkDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="UCLK"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="48" />
                            <TextBlock Text="{Binding UclkDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── TIMING GROUPS (vendor-ordered, dynamic) ───────── -->
                <!-- BiosLayoutLabel is non-empty only when a specific vendor was detected. -->
                <TextBlock Text="{Binding BiosLayoutLabel}"
                           Foreground="{StaticResource TextSecondary}"
                           FontFamily="{StaticResource UIFont}"
                           FontSize="10"
                           Margin="0,0,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <!-- Visible by default; collapse when label is empty or null. -->
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BiosLayoutLabel}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding BiosLayoutLabel}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Two-column masonry layout.
                     Each column is an independent StackPanel so groups pack tight
                     with no row alignment forced across columns (fixes wasted space
                     when groups have different heights).
                     GroupColumnConverter does greedy bin-packing by estimated height. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left column -->
                    <ItemsControl Grid.Column="0"
                                  ItemsSource="{Binding TimingDisplayGroups,
                                      Converter={StaticResource GroupsToLeftColumn},
                                      ConverterParameter=0}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding GroupName}"
                                               Style="{StaticResource SectionHeader}" />
                                    <Border Background="{StaticResource BgPanel}"
                                            CornerRadius="2"
                                            Padding="12,8"
                                            Margin="0,4,0,0">
                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                Height="24"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontFamily="{StaticResource UIFont}"
                                                                   FontSize="12"
                                                                   Width="80"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Value}"
                                                                   Style="{StaticResource MonoText}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Right column -->
                    <ItemsControl Grid.Column="2"
                                  ItemsSource="{Binding TimingDisplayGroups,
                                      Converter={StaticResource GroupsToRightColumn},
                                      ConverterParameter=1}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding GroupName}"
                                               Style="{StaticResource SectionHeader}" />
                                    <Border Background="{StaticResource BgPanel}"
                                            CornerRadius="2"
                                            Padding="12,8"
                                            Margin="0,4,0,0">
                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                Height="24"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontFamily="{StaticResource UIFont}"
                                                                   FontSize="12"
                                                                   Width="80"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Value}"
                                                                   Style="{StaticResource MonoText}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- ── VOLTAGES ────────────────────────────────────────── -->
                <TextBlock Text="VOLTAGES" Style="{StaticResource SectionHeader}" />
                <Border Background="{StaticResource BgPanel}"
                        CornerRadius="2"
                        Padding="12,8"
                        Margin="0,4,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="VSoC"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding VsocDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="VDIMM"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       Width="56" />
                            <TextBlock Text="{Binding VdimmDisplay}"
                                       Style="{StaticResource MonoText}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── ACTIONS ────────────────────────────────────────── -->
                <!-- DataContext is MainViewModel (set at tab level by MainWindow) -->
                <Border Margin="0,12,0,0"
                        Padding="0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Save Snapshot"
                                Click="OnSaveSnapshot"
                                Padding="12,5"
                                FontFamily="{StaticResource UIFont}"
                                FontSize="12"
                                AutomationProperties.Name="Save Snapshot" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
