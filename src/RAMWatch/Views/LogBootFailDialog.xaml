<Window x:Class="RAMWatch.Views.LogBootFailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Failed Boot Attempt"
        Width="460" Height="500"
        MinWidth="400" MinHeight="440"
        Style="{StaticResource DarkWindow}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        AutomationProperties.Name="Log Failed Boot Attempt">

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header -->
            <RowDefinition Height="Auto" />   <!-- Description -->
            <RowDefinition Height="Auto" />   <!-- Kind -->
            <RowDefinition Height="Auto" />   <!-- Attempted Changes label -->
            <RowDefinition Height="*" />      <!-- Attempted Changes editor -->
            <RowDefinition Height="Auto" />   <!-- Notes label -->
            <RowDefinition Height="100" />    <!-- Notes editor -->
            <RowDefinition Height="Auto" />   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="LOG FAILED BOOT ATTEMPT"
                   Style="{StaticResource SectionHeader}"
                   Margin="0,0,0,6" />

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="Use this when RAMWatch missed the capture — a config that didn't POST, crashed before login, or died too fast to read UMC. Tell us what you tried; we'll remember it."
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <!-- Kind -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Failure type"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="11"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      x:Name="KindCombo"
                      Style="{StaticResource DarkComboBox}"
                      ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                      AutomationProperties.Name="Failure type" />
        </Grid>

        <!-- Attempted changes label -->
        <TextBlock Grid.Row="3"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="11"
                   Margin="0,0,0,3">
            <Run Text="Attempted changes" />
            <Run Text="  —  one per line, FIELD=VALUE"
                 Foreground="{StaticResource TextDisabled}"
                 FontSize="10" />
        </TextBlock>

        <!-- Attempted changes editor -->
        <TextBox Grid.Row="4"
                 x:Name="ChangesBox"
                 AcceptsReturn="True"
                 AcceptsTab="False"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Background="{StaticResource BgAccent}"
                 Foreground="{StaticResource TextPrimary}"
                 BorderThickness="0"
                 Padding="6,6"
                 FontFamily="{StaticResource MonoFont}"
                 Margin="0,0,0,12"
                 AutomationProperties.Name="Attempted changes" />

        <!-- Notes label -->
        <TextBlock Grid.Row="5"
                   Text="Notes"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="11"
                   Margin="0,0,0,3" />

        <!-- Notes editor -->
        <TextBox Grid.Row="6"
                 x:Name="NotesBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="{StaticResource BgAccent}"
                 Foreground="{StaticResource TextPrimary}"
                 BorderThickness="0"
                 Padding="6,6"
                 FontFamily="{StaticResource UIFont}"
                 Margin="0,0,0,12"
                 AutomationProperties.Name="Notes" />

        <!-- Buttons -->
        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Name="ValidationErrorText"
                       Foreground="{StaticResource StatusAmber}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />

            <Button Grid.Column="1"
                    Content="Log Attempt"
                    Style="{StaticResource DarkButton}"
                    Width="100"
                    Click="OnLogAttempt"
                    IsDefault="True"
                    AutomationProperties.Name="Log Attempt" />

            <Button Grid.Column="3"
                    Content="Cancel"
                    Style="{StaticResource DarkButton}"
                    Width="70"
                    Click="OnCancel"
                    IsCancel="True"
                    AutomationProperties.Name="Cancel" />
        </Grid>
    </Grid>
</Window>
