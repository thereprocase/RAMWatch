<UserControl x:Class="RAMWatch.Views.SnapshotsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Section header -->
            <RowDefinition Height="Auto" />   <!-- Dropdown selectors -->
            <RowDefinition Height="*" />      <!-- Comparison grid -->
        </Grid.RowDefinitions>

        <!-- Section header -->
        <TextBlock Grid.Row="0"
                   Text="SNAPSHOT COMPARISON"
                   Style="{StaticResource SectionHeader}" />

        <!-- Empty state (no snapshots at all) -->
        <TextBlock Grid.Row="2"
                   Text="Save a snapshot to enable comparison."
                   Foreground="{StaticResource TextSecondary}"
                   FontStyle="Italic"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="{Binding HasSnapshots, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                   AutomationProperties.Name="Snapshots empty" />

        <!-- Dropdowns row -->
        <Grid Grid.Row="1" Margin="0,4,0,8"
              Visibility="{Binding HasSnapshots, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Compare:"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding AvailableSnapshots}"
                      SelectedItem="{Binding LeftSelection}"
                      DisplayMemberPath="DisplayName"
                      Background="{StaticResource BgPanel}"
                      Foreground="{StaticResource TextPrimary}"
                      AutomationProperties.Name="Left snapshot"
                      Margin="0,0,8,0" />

            <TextBlock Grid.Column="2"
                       Text="vs"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox Grid.Column="3"
                      ItemsSource="{Binding AvailableSnapshots}"
                      SelectedItem="{Binding RightSelection}"
                      DisplayMemberPath="DisplayName"
                      Background="{StaticResource BgPanel}"
                      Foreground="{StaticResource TextPrimary}"
                      AutomationProperties.Name="Right snapshot" />
        </Grid>

        <!-- Comparison DataGrid -->
        <DataGrid Grid.Row="2"
                  Style="{StaticResource DarkDataGrid}"
                  ItemsSource="{Binding ComparisonRows}"
                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}"
                  AutomationProperties.Name="Snapshot comparison"
                  Visibility="{Binding HasComparison, Converter={StaticResource BoolToVisibility}}">

            <!-- Override default WPF blue row selection highlight -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgHover}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <!-- Suppress default cell selection highlight -->
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <!-- Timing name -->
                <DataGridTextColumn Header="Timing" Binding="{Binding TimingName}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Left value -->
                <DataGridTextColumn Header="Left" Binding="{Binding LeftValue}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Right value -->
                <DataGridTextColumn Header="Right" Binding="{Binding RightValue}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Delta -->
                <DataGridTextColumn Header="Delta" Binding="{Binding Delta}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                            <Setter Property="Foreground"
                                    Value="{Binding Direction,
                                            Converter={StaticResource DirectionToColor}}" />
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
