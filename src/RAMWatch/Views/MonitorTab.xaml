<UserControl x:Class="RAMWatch.Views.MonitorTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RAMWatch.Controls">

    <UserControl.Resources>
        <!-- Group the error source collection by IsStability so stability sources
             appear above system sources with a labelled separator between them. -->
        <CollectionViewSource x:Key="GroupedErrorSources"
                              Source="{Binding ErrorSources}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="IsStability" />
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <!-- IsStability=True (stability) sorts before False (system) in descending order.
                     Within each group sort by descending count so active sources surface first. -->
                <ComponentModel:SortDescription xmlns:ComponentModel="clr-namespace:System.ComponentModel;assembly=WindowsBase"
                                                PropertyName="IsStability"
                                                Direction="Descending" />
                <ComponentModel:SortDescription xmlns:ComponentModel="clr-namespace:System.ComponentModel;assembly=WindowsBase"
                                                PropertyName="Count"
                                                Direction="Descending" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>

    <Grid Margin="8,8,8,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Cold-boot-pending banner (collapsed when ready) -->
            <RowDefinition Height="Auto" />   <!-- Section header + three-axis legend -->
            <RowDefinition Height="Auto" />   <!-- Error table (auto-sized, not star) -->
            <RowDefinition Height="*" />      <!-- Spacer — pushes integrity to bottom -->
            <RowDefinition Height="Auto" />   <!-- Integrity section header -->
            <RowDefinition Height="Auto" />   <!-- Integrity panel -->
        </Grid.RowDefinitions>

        <!-- Cold-boot banner. Visible only while the service is still inside
             the startup window (ColdBootComplete=false); pre-tracking servers
             send null which the VM maps to true → banner stays hidden. The
             message is informational, not alarming — it tells the user why
             certain tuning affordances may be dimmed on other tabs. -->
        <Border Grid.Row="0"
                Background="#33FFB300"
                BorderBrush="{StaticResource StatusAmber}"
                BorderThickness="1"
                CornerRadius="2"
                Padding="8,4"
                Margin="0,0,0,6"
                Visibility="{Binding ColdBootComplete,
                                     Converter={StaticResource BoolToVisibility},
                                     ConverterParameter=Invert}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x26A0;"
                           Foreground="{StaticResource StatusAmber}"
                           FontFamily="{StaticResource UIFont}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Foreground="{StaticResource TextPrimary}"
                           FontFamily="{StaticResource UIFont}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Text="Cold-boot readers still loading — hardware state will finish populating shortly. Drift detection and peer tuning actions are gated until the sweep completes." />
            </StackPanel>
        </Border>

        <!-- Error Monitor header. Glyph conveys the section's data tier —
             everything below is a live push from Windows Event Log, not a
             periodic scan.

             LastChildFill="False" is load-bearing: with the default (True),
             the last child ignores its Dock value and fills the remaining
             row width, which made the subtitle left-align flush against
             "MONITOR" instead of docking to the right edge.

             TextBlocks override SectionHeader's Margin="0,4,0,2" so the
             label's visual baseline lines up with the vertically-centered
             glyph instead of sitting below it. -->
        <DockPanel Grid.Row="1" LastChildFill="False">
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Left"
                        VerticalAlignment="Center">
                <controls:ProvenanceGlyph SensorKey="EventMonitor" DisplayName="Error Monitor"
                                          VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="ERROR MONITOR"
                           Style="{StaticResource SectionHeader}"
                           VerticalAlignment="Center"
                           Margin="0" />
            </StackPanel>
            <!-- Right-docked: double-click hint only; legend lives in the header. -->
            <TextBlock DockPanel.Dock="Right"
                       Text="Double-click a row for decoded details"
                       Foreground="{StaticResource TextDisabled}"
                       FontFamily="{StaticResource UIFont}"
                       FontSize="10"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
        </DockPanel>

        <!-- Error source table — grouped by severity tier (Stability / System).
             CanContentScroll=False forces pixel-based scrolling which measures columns
             correctly when GroupStyle is active (virtualized scrolling breaks column widths). -->
        <DataGrid x:Name="ErrorGrid"
                  Grid.Row="2"
                  Style="{StaticResource DarkDataGrid}"
                  ItemsSource="{Binding Source={StaticResource GroupedErrorSources}}"
                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}"
                  AutomationProperties.Name="Error Monitor"
                  ScrollViewer.CanContentScroll="False"
                  VerticalAlignment="Top"
                  Margin="0,2,0,8"
                  MouseDoubleClick="OnErrorRowDoubleClick">

            <!-- Group header row: "STABILITY" or "SYSTEM" label separates the two tiers. -->
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgAccent}"
                                    Padding="8,3">
                                <TextBlock FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="SYSTEM" />
                                            <Style.Triggers>
                                                <!-- Name is the group key (True for stability, False for system) -->
                                                <DataTrigger Binding="{Binding Name}" Value="True">
                                                    <Setter Property="Text" Value="STABILITY" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="GroupItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GroupItem">
                                        <StackPanel>
                                            <ContentPresenter />
                                            <ItemsPresenter />
                                        </StackPanel>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>

            <!-- Override default WPF blue row selection highlight. Hand cursor
                 signals to a returning user that rows are interactive — without
                 it, double-click-for-detail is undiscoverable. -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Cursor" Value="Hand" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgHover}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                        </Trigger>
                        <!-- Dim zero-count rows so "nothing happened" is instantly visible -->
                        <DataTrigger Binding="{Binding CountSeverity}" Value="None">
                            <Setter Property="Opacity" Value="0.5" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <!-- Suppress default cell selection highlight so row style shows through -->
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Source" Binding="{Binding Name}" Width="*" MinWidth="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Style.Triggers>
                                <!-- Normal: baseline-expected count — bold but not alarming -->
                                <DataTrigger Binding="{Binding CountSeverity}" Value="Normal">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                                <!-- Elevated: above baseline — amber -->
                                <DataTrigger Binding="{Binding CountSeverity}" Value="Elevated">
                                    <Setter Property="Foreground" Value="{StaticResource StatusAmber}" />
                                </DataTrigger>
                                <!-- High: well above baseline or hardware error — red -->
                                <DataTrigger Binding="{Binding CountSeverity}" Value="High">
                                    <Setter Property="Foreground" Value="{StaticResource StatusRed}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="Auto" MinWidth="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="Auto" MinWidth="50">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CountSeverity}" Value="Normal">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CountSeverity}" Value="Elevated">
                                    <Setter Property="Foreground" Value="{StaticResource StatusAmber}" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CountSeverity}" Value="High">
                                    <Setter Property="Foreground" Value="{StaticResource StatusRed}" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen, TargetNullValue='-'}" Width="Auto" MinWidth="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Normal" Binding="{Binding BaselineText}" Width="Auto" MinWidth="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                            <Setter Property="FontSize" Value="11" />
                            <Setter Property="Foreground" Value="{StaticResource TextDisabled}" />
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Integrity header. Glyph conveys the section's data tier — CBS.log
             is polled every warm tick (30–60s); SFC/DISM rows only appear
             when the user has run those tools.

             Margin left of 8 aligns the header glyph with the CBS.log row
             glyph inside the panel below (Border.Padding="8,4"). Without it
             the header dot sat at x=0 and the row dots at x=8, visibly
             stepped. Label Margin="0" overrides SectionHeader's default
             top/bottom to keep the glyph on the text's vertical centre. -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0">
            <controls:ProvenanceGlyph SensorKey="Integrity" DisplayName="Integrity"
                                      VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBlock Text="INTEGRITY"
                       Style="{StaticResource SectionHeader}"
                       VerticalAlignment="Center"
                       Margin="0" />
        </StackPanel>

        <!-- Integrity panel -->
        <Border Grid.Row="5"
                Background="{StaticResource BgPanel}"
                CornerRadius="2"
                Padding="8,4"
                Margin="0,2,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource TextDisabled}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CbsStatus}" Value="Clean">
                                        <Setter Property="Fill" Value="{StaticResource StatusGreen}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Foreground="{StaticResource TextPrimary}">
                        <Run Text="CBS.log: " />
                        <Run Text="{Binding CbsStatus, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SfcStatus}" Value="Not run">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource TextDisabled}" Margin="0,0,8,0" />
                    <TextBlock Foreground="{StaticResource TextSecondary}">
                        <Run Text="SFC: " />
                        <Run Text="{Binding SfcStatus, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DismStatus}" Value="Not run">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource TextDisabled}" Margin="0,0,8,0" />
                    <TextBlock Foreground="{StaticResource TextSecondary}">
                        <Run Text="DISM: " />
                        <Run Text="{Binding DismStatus, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
