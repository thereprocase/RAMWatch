<Window x:Class="RAMWatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RAMWatch.ViewModels"
        xmlns:views="clr-namespace:RAMWatch.Views"
        Title="RAMWatch" Width="520" Height="640"
        MinWidth="440" MinHeight="400"
        Style="{StaticResource DarkWindow}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Status header -->
            <RowDefinition Height="Auto" />  <!-- Separator -->
            <RowDefinition Height="*" />     <!-- Tab content -->
            <RowDefinition Height="Auto" />  <!-- Separator -->
            <RowDefinition Height="Auto" />  <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- Status Header (56px, always visible) -->
        <Border Grid.Row="0" Padding="16,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Status dot -->
                    <Ellipse Width="14" Height="14" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource TextDisabled}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusColor}" Value="Green">
                                        <Setter Property="Fill" Value="{StaticResource StatusGreen}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusColor}" Value="Red">
                                        <Setter Property="Fill" Value="{StaticResource StatusRed}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusColor}" Value="Amber">
                                        <Setter Property="Fill" Value="{StaticResource StatusAmber}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Status text -->
                    <TextBlock FontSize="14" FontWeight="Bold" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextDisabled}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusColor}" Value="Green">
                                        <Setter Property="Foreground" Value="{StaticResource StatusGreen}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusColor}" Value="Red">
                                        <Setter Property="Foreground" Value="{StaticResource StatusRed}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding StatusText, Mode=OneWay}" />
                        <Run Text=" — " Foreground="{StaticResource TextSecondary}" />
                        <Run Text="{Binding TotalErrorCount, Mode=OneWay, StringFormat='{}{0} errors since boot'}"
                             Foreground="{StaticResource TextSecondary}" />
                    </TextBlock>
                </StackPanel>

                <!-- Metadata line -->
                <TextBlock Style="{StaticResource SecondaryText}" Margin="22,2,0,0">
                    <Run Text="{Binding BootTimeText, Mode=OneWay}" />
                    <Run Text="  |  " />
                    <Run Text="{Binding UptimeText, Mode=OneWay}" />
                    <Run Text="  |  " />
                    <Run Text="{Binding LastUpdateText, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Separator -->
        <Border Grid.Row="1" Height="1" Background="{StaticResource BgAccent}" />

        <!-- Tab Control -->
        <TabControl Grid.Row="2" x:Name="MainTabControl"
                    Style="{StaticResource DarkTabControl}">
            <TabItem Header="Monitor" Style="{StaticResource DarkTabItem}">
                <views:MonitorTab />
            </TabItem>
            <TabItem Header="Timings" Style="{StaticResource DarkTabItem}">
                <views:TimingsTab DataContext="{Binding Timings}" />
            </TabItem>
            <TabItem Header="Settings" Style="{StaticResource DarkTabItem}">
                <views:SettingsTab x:Name="SettingsTabContent" />
            </TabItem>
        </TabControl>

        <!-- Separator -->
        <Border Grid.Row="3" Height="1" Background="{StaticResource BgAccent}" />

        <!-- Action bar -->
        <Border Grid.Row="4" Padding="16,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Copy to Clipboard"
                        Style="{StaticResource DarkButton}"
                        Command="{Binding CopyToClipboardCommand}"
                        Margin="0,0,8,0" />
                <Button Content="Refresh"
                        Style="{StaticResource DarkButton}"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Border>

        <!-- Connection banner (shown when not connected) -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#CC1A1A2E"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                VerticalAlignment="Top" Margin="0,56,0,0"
                Padding="16,8">
            <TextBlock Text="{Binding ConnectionStatus}"
                       Foreground="{StaticResource StatusAmber}"
                       FontSize="12" />
        </Border>
    </Grid>
</Window>
