<UserControl x:Class="RAMWatch.Controls.DotLegend"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="LegendMeasuredLive" Color="#4ADE80" />
        <SolidColorBrush x:Key="LegendMeasuredWarm" Color="#2E8E56" />
        <SolidColorBrush x:Key="LegendMeasuredCold" Color="#1B4D30" />
        <SolidColorBrush x:Key="LegendStaticLive"   Color="#9CA3AF" />
        <SolidColorBrush x:Key="LegendPass"  Color="#4ADE80" />
        <SolidColorBrush x:Key="LegendWarn"  Color="#FBBF24" />
        <SolidColorBrush x:Key="LegendCrit"  Color="#EF4444" />

        <Style x:Key="LegendLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDisabled}" />
            <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
            <Setter Property="FontSize"   Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin"     Value="3,0,10,0" />
        </Style>
        <Style x:Key="LegendCell" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,1,0,1" />
        </Style>
    </UserControl.Resources>

    <!-- 3×3: rows = provenance / freshness / status, cols = item 1/2/3 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: shape → provenance -->
        <StackPanel Grid.Row="0" Grid.Column="0" Style="{StaticResource LegendCell}">
            <Ellipse Width="8" Height="8" Fill="{StaticResource LegendMeasuredLive}" VerticalAlignment="Center" />
            <TextBlock Text="measured" Style="{StaticResource LegendLabel}" />
        </StackPanel>
        <StackPanel Grid.Row="0" Grid.Column="1" Style="{StaticResource LegendCell}">
            <Path Fill="{StaticResource LegendMeasuredLive}"
                  Data="M 4,0 L 8,4 L 4,8 L 0,4 Z"
                  Width="8" Height="8" VerticalAlignment="Center" />
            <TextBlock Text="derived" Style="{StaticResource LegendLabel}" />
        </StackPanel>
        <StackPanel Grid.Row="0" Grid.Column="2" Style="{StaticResource LegendCell}">
            <Rectangle Width="8" Height="8" Fill="{StaticResource LegendStaticLive}" VerticalAlignment="Center" />
            <TextBlock Text="unknown" Style="{StaticResource LegendLabel}" />
        </StackPanel>

        <!-- Row 1: fill saturation → freshness -->
        <StackPanel Grid.Row="1" Grid.Column="0" Style="{StaticResource LegendCell}">
            <Ellipse Width="8" Height="8" Fill="{StaticResource LegendMeasuredLive}" VerticalAlignment="Center" />
            <TextBlock Text="live"  Style="{StaticResource LegendLabel}" />
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1" Style="{StaticResource LegendCell}">
            <Ellipse Width="8" Height="8" Fill="{StaticResource LegendMeasuredWarm}" VerticalAlignment="Center" />
            <TextBlock Text="warm" Style="{StaticResource LegendLabel}" />
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="2" Style="{StaticResource LegendCell}">
            <Ellipse Width="8" Height="8" Fill="{StaticResource LegendMeasuredCold}" VerticalAlignment="Center" />
            <TextBlock Text="cold" Style="{StaticResource LegendLabel}" />
        </StackPanel>

        <!-- Row 2: border ring → status -->
        <StackPanel Grid.Row="2" Grid.Column="0" Style="{StaticResource LegendCell}">
            <Ellipse Width="8" Height="8" Fill="Transparent"
                     Stroke="{StaticResource LegendPass}" StrokeThickness="1" VerticalAlignment="Center" />
            <TextBlock Text="pass" Style="{StaticResource LegendLabel}" />
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="1" Style="{StaticResource LegendCell}">
            <Ellipse Width="8" Height="8" Fill="Transparent"
                     Stroke="{StaticResource LegendWarn}" StrokeThickness="1" VerticalAlignment="Center" />
            <TextBlock Text="warn" Style="{StaticResource LegendLabel}" />
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="2" Style="{StaticResource LegendCell}">
            <Ellipse Width="8" Height="8" Fill="Transparent"
                     Stroke="{StaticResource LegendCrit}" StrokeThickness="1" VerticalAlignment="Center" />
            <TextBlock Text="crit" Style="{StaticResource LegendLabel}" />
        </StackPanel>
    </Grid>
</UserControl>
