<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds — dark slate/charcoal with barely-perceptible cool undertone -->
    <Color x:Key="BgPrimaryColor">#1B1D21</Color>
    <Color x:Key="BgPanelColor">#252830</Color>
    <Color x:Key="BgAccentColor">#2E3239</Color>
    <Color x:Key="BgHoverColor">#363A42</Color>
    <Color x:Key="BgAlternateRowColor">#21242A</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#E0E0E0</Color>
    <Color x:Key="TextSecondaryColor">#9DA3AE</Color>
    <Color x:Key="TextDisabledColor">#7A8090</Color>

    <!-- Semantic -->
    <Color x:Key="StatusGreenColor">#00C853</Color>
    <Color x:Key="StatusRedColor">#FF1744</Color>
    <Color x:Key="StatusAmberColor">#FFB300</Color>
    <Color x:Key="InteractiveBlueColor">#5B8AD9</Color>

    <!-- Border -->
    <Color x:Key="BorderSubtleColor">#363A42</Color>
    <Color x:Key="BorderFocusColor">#5B8AD9</Color>

    <!-- SolidColorBrushes for binding -->
    <SolidColorBrush x:Key="BgPrimary" Color="{StaticResource BgPrimaryColor}" />
    <SolidColorBrush x:Key="BgPanel" Color="{StaticResource BgPanelColor}" />
    <SolidColorBrush x:Key="BgAccent" Color="{StaticResource BgAccentColor}" />
    <SolidColorBrush x:Key="BgHover" Color="{StaticResource BgHoverColor}" />
    <SolidColorBrush x:Key="BgAlternateRow" Color="{StaticResource BgAlternateRowColor}" />
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextDisabled" Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="StatusGreen" Color="{StaticResource StatusGreenColor}" />
    <SolidColorBrush x:Key="StatusRed" Color="{StaticResource StatusRedColor}" />
    <SolidColorBrush x:Key="StatusAmber" Color="{StaticResource StatusAmberColor}" />
    <SolidColorBrush x:Key="InteractiveBlue" Color="{StaticResource InteractiveBlueColor}" />
    <SolidColorBrush x:Key="BorderSubtle" Color="{StaticResource BorderSubtleColor}" />
    <SolidColorBrush x:Key="BorderFocus" Color="{StaticResource BorderFocusColor}" />

    <!-- Typography -->
    <FontFamily x:Key="MonoFont">./#JetBrainsMono Nerd Font, Cascadia Mono, Consolas, monospace</FontFamily>
    <FontFamily x:Key="UIFont">Segoe UI, system-ui, sans-serif</FontFamily>

    <!-- Focus visual ring — keyboard navigation indicator -->
    <Style x:Key="FocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle StrokeThickness="2" Stroke="{StaticResource InteractiveBlue}"
                               SnapsToDevicePixels="true" Margin="-2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window -->
    <Style TargetType="Window" x:Key="DarkWindow">
        <Setter Property="Background" Value="{StaticResource BgPrimary}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Button -->
    <Style TargetType="Button" x:Key="DarkButton">
        <Setter Property="Background" Value="{StaticResource BgAccent}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#1B1D21" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#2E3239" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource TextDisabled}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabControl
         Uses a WrapPanel instead of TabPanel so rows never reorder on selection.
         Wide → single row; narrow → wraps in source order (1-3 top, 4-6 bottom). -->
    <Style TargetType="TabControl" x:Key="DarkTabControl">
        <Setter Property="Background" Value="{StaticResource BgPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <DockPanel KeyboardNavigation.TabNavigation="Local">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource BgPrimary}"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{StaticResource BgAccent}">
                            <ItemsPresenter KeyboardNavigation.TabIndex="1" />
                        </Border>
                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                          ContentSource="SelectedContent"
                                          KeyboardNavigation.TabIndex="2"
                                          KeyboardNavigation.DirectionalNavigation="Contained" />
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem" x:Key="DarkTabItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderThickness="0,0,0,2"
                            BorderBrush="Transparent">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background"
                                    Value="{StaticResource BgHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background"
                                    Value="{StaticResource BgAccent}" />
                            <Setter Property="Foreground"
                                    Value="{StaticResource TextPrimary}" />
                            <Setter TargetName="Border" Property="BorderBrush"
                                    Value="{StaticResource InteractiveBlue}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid -->
    <Style TargetType="DataGrid" x:Key="DarkDataGrid">
        <Setter Property="Background" Value="{StaticResource BgPanel}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="RowBackground" Value="{StaticResource BgPanel}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource BgAlternateRow}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="RowHeight" Value="22" />
        <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="CanUserResizeRows" Value="False" />
    </Style>

    <Style TargetType="DataGridColumnHeader" x:Key="DarkColumnHeader">
        <Setter Property="Background" Value="{StaticResource BgAccent}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- TextBlock defaults -->
    <Style TargetType="TextBlock" x:Key="SecondaryText">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style TargetType="TextBlock" x:Key="MonoText">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Expander used in SettingsTab sections -->
    <Style TargetType="Expander" x:Key="DarkExpander">
        <Setter Property="Background" Value="{StaticResource BgPanel}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="IsExpanded" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <StackPanel>
                        <!-- Header toggle -->
                        <ToggleButton x:Name="HeaderSite"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Background="{StaticResource BgPanel}"
                                      BorderThickness="0"
                                      Padding="12,8"
                                      HorizontalContentAlignment="Left"
                                      FocusVisualStyle="{StaticResource FocusVisual}"
                                      Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="2,2,0,0"
                                            Padding="{TemplateBinding Padding}">
                                        <DockPanel>
                                            <!-- Chevron -->
                                            <TextBlock x:Name="Arrow"
                                                       DockPanel.Dock="Right"
                                                       Text="▾"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0" />
                                            <ContentPresenter />
                                        </DockPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter TargetName="Arrow" Property="Text" Value="▸" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BgHover}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </ToggleButton>
                        <!-- Collapsible body -->
                        <ContentPresenter x:Name="ExpandSite"
                                          Visibility="Collapsed" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Section header (e.g., "Error Monitor", "Integrity") -->
    <Style TargetType="TextBlock" x:Key="SectionHeader">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
        <Setter Property="Margin" Value="0,4,0,2" />
    </Style>

    <!-- ComboBox — full dark template so the popup background and item highlight
         respect the dark theme. WPF's default template renders the popup in the
         system chrome color regardless of Background bindings on the control. -->
    <Style TargetType="ComboBox" x:Key="DarkComboBox">
        <Setter Property="Background" Value="{StaticResource BgAccent}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Main selection box -->
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                </Grid.ColumnDefinitions>
                                <!-- Selected item presenter -->
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                                <!-- Drop arrow -->
                                <TextBlock Grid.Column="1"
                                           Text="▾"
                                           FontSize="10"
                                           Foreground="{StaticResource TextSecondary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Transparent button to capture IsDropDownOpen toggle -->
                        <ToggleButton IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Focusable="False"
                                      IsHitTestVisible="True">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Dropdown popup -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade"
                               Placement="Bottom">
                            <Border Background="{StaticResource BgPanel}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="{StaticResource BgHover}" />
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource BorderFocus}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource BorderFocus}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="MainBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#2E3239" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource TextDisabled}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBoxItem — applied to all items inside a DarkComboBox -->
    <Style TargetType="ComboBoxItem" x:Key="DarkComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgAccent}" />
                            <Setter Property="Foreground" Value="{StaticResource InteractiveBlue}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{StaticResource BgHover}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
