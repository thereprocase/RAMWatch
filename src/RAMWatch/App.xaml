<Application x:Class="RAMWatch.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RAMWatch.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Dark.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:SeverityToColorConverter x:Key="SeverityToColor" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:ComparisonDirectionToColorConverter x:Key="DirectionToColor" />
            <conv:GroupColumnConverter x:Key="GroupsToLeftColumn" />
            <conv:GroupColumnConverter x:Key="GroupsToRightColumn" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
